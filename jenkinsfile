pipeline {
 agent any

 stages {

 stage('Git Pull') {
 steps {
 git 'https://github.com/Sreev10/project.git'
 }
 }

 stage('Build') {
 steps {
 sh 'mvn clean package'
 }
 }

 stage('Docker Build') {
 steps {
 sh 'docker build -t employee-app .'
 }
 }

 stage('Deploy K8s') {
 steps {
 sh 'kubectl apply -f deployment.yaml'
 }
 }

 }

}
